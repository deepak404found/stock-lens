NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
# Production (Render): set CORS_ORIGIN to your Vercel URL with no trailing slash
# CORS_ORIGIN=https://stock-lens-tau.vercel.app
COOKIE_NAME=stocklens_token
SEED_USER_EMAIL=admin@stocklens.com
SEED_USER_PASSWORD=StockLens@123
SEED_USER_FULL_NAME=StockLens Admin

# Redpanda Cloud (Kafka-compatible) — required for Phase 2
# Use the *.any.* bootstrap address from Redpanda Cloud console (port 9092, SASL_SSL)
KAFKA_BROKERS=seed-xxxxx.any.region.mpx.prd.cloud.redpanda.com:9092
KAFKA_USERNAME=your-sasl-username
KAFKA_PASSWORD=your-sasl-password
KAFKA_TOPIC_INVENTORY_EVENTS=inventory-events
KAFKA_CONSUMER_GROUP=stocklens-inventory-consumer
KAFKA_SSL=true
# KafkaJS uses ssl: {} internally when true (TLS via system CAs)
